# ─────────────────────────────────────────────────────────────────────────────
# election-portal — environment variables
# Copy this file to .env and fill in the values before starting the dev server.
# Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the election-api backend (Supabase-backed). No trailing slash.
# Local dev — point at election-api on your machine:
# VITE_API_URL=http://localhost:8000
# Production / shared API (DigitalOcean):
VITE_API_URL=https://election-api-vbpil.ondigitalocean.app

# Port for the local dev proxy server (Express + Vite HMR).
# Default: 4000 — must be listed in election-api FRONTEND_URLS for CORS.
VITE_PORT=4000

# ── Netlify production ─────────────────────────────────────────────────────────
# Netlify builds a static SPA (npm run build → dist/public).
# API calls use /api/* redirects in netlify.toml → election-api (no .env needed
# on Netlify for VITE_API_URL unless you embed it at build time).
#
# Set in Netlify UI if you change the API host:
#   VITE_API_URL=https://election-api-vbpil.ondigitalocean.app
