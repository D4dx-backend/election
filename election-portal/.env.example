# ─────────────────────────────────────────────────────────────────────────────
# election-portal — environment variables
# Copy this file to .env and fill in the values before starting the server.
# Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# URL of the election-api backend (no trailing slash).
# Local dev (Supabase-backed election-api):
VITE_API_URL=https://election-api-vbpil.ondigitalocean.app
# Production (deploy latest election-api with Supabase env vars first):
# VITE_API_URL=https://election-api-vbpil.ondigitalocean.app

# Port for the portal Express / dev server.
# Default: 4000  (must be listed in election-api FRONTEND_URLS for CORS).
VITE_PORT=4000

# ── Optional: only needed if you use `npm run db:push` (Drizzle / Postgres) ──
# The live app uses MongoDB via election-api; this is only needed if you are
# running Drizzle schema migrations against a PostgreSQL instance.
# DATABASE_URL=postgresql://user:password@localhost:5432/election_db
