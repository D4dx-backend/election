# ─────────────────────────────────────────────────────────────────────────────
# election-api — environment variables
# Copy this file to .env and fill in the values before starting the API.
# Never commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (required)
# Found in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (required — server-side only, never expose to clients)
# Found in Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct Postgres connection (required for `npm run migrate` only)
# Supabase Dashboard → Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT secret — must be a long, random string.
# The portal reads tokens signed with this secret via Bearer auth.
JWT_SECRET=your_strong_secret_here_min_32_chars

# Server port (default: 8000)
PORT=8000

# Node environment: development | production
NODE_ENV=development

# ── DigitalOcean App Platform ────────────────────────────────────────────────
# Deploy election-api from the election-api/ directory (Dockerfile).
# Required runtime env vars on DigitalOcean (remove any legacy MONGO_URI):
#   SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   JWT_SECRET          (must match what signed existing user tokens)
#   NODE_ENV=production
#   FRONTEND_URLS       (optional, comma-separated extra CORS origins)
# PORT is injected automatically by App Platform — do not hardcode in production.
# Health check path: GET /health
# Production URL (Netlify proxies here): https://election-api-vbpil.ondigitalocean.app

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of additional frontend URLs allowed by CORS.
# The following origins are always allowed (built into index.js):
#   http://localhost:4000  (portal dev server)
#   http://localhost:3001, 3002, 8000, 8001
#   https://election-portal-web.netlify.app
#
# Add your production frontend URL here if it's different:
# FRONTEND_URLS=https://your-custom-domain.com,https://another-domain.com

# ── Optional: email / notifications ──────────────────────────────────────────
# Required for "Send Reminder" emails in Analytics
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Vote+ Elections <your@email.com>

# ── DigitalOcean Spaces CDN (image uploads) ───────────────────────────────────
# Required in production for franchise logos, election logos, and nominee photos.
# Create a Space in DigitalOcean → enable CDN → create API keys with read/write.
# DO_SPACES_KEY=your_spaces_access_key
# DO_SPACES_SECRET=your_spaces_secret_key
# DO_SPACES_BUCKET=your-space-name
# DO_SPACES_REGION=blr1
# DO_SPACES_ENDPOINT=blr1.digitaloceanspaces.com
# DO_SPACES_CDN_URL=https://your-space-name.blr1.cdn.digitaloceanspaces.com
# DO_SPACES_CDN_ENDPOINT=https://your-space-name.blr1.cdn.digitaloceanspaces.com
# DO_SPACES_FOLDER=Election

# ── Optional: Cloudinary (legacy — not used when Spaces is configured) ────────
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
